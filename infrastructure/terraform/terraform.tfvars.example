# BlockScore Terraform Variables Example
# Copy this file and fill in your values.
# NEVER commit sensitive values to version control.
# Set db_password via environment variable: export TF_VAR_db_password="your-secure-password"

aws_region  = "us-west-2"
environment = "dev"
app_name    = "blockscore"

vpc_cidr             = "10.0.0.0/16"
availability_zones   = ["us-west-2a", "us-west-2b", "us-west-2c"]
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnet_cidrs = ["10.0.4.0/24", "10.0.5.0/24", "10.0.6.0/24"]

instance_type        = "t3.micro"
key_name             = "your-key-pair-name"
asg_min_size         = 1
asg_max_size         = 3
asg_desired_capacity = 1

# acm_certificate_arn = "arn:aws:acm:us-west-2:ACCOUNT_ID:certificate/..."

db_instance_class    = "db.t3.micro"
db_name              = "blockscoredb"
db_username          = "blockscore_admin"
db_allocated_storage = 20
# db_password is intentionally omitted - use TF_VAR_db_password env var

default_tags = {
  Terraform   = "true"
  Environment = "dev"
  Project     = "blockscore"
}
